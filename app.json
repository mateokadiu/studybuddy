{
  "expo": {
    "name": "studybuddy",
    "slug": "studybuddy",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "studybuddy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mateokadiu.studybuddy"
    },
    "android": {
      "package": "com.mateokadiu.studybuddy",
      "adaptiveIcon": {
        "backgroundColor": "#0f1115"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-document-picker", "expo-notifications"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
